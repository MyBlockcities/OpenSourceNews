# API Authentication (leave blank to disable auth in dev)
OPEN_SOURCE_NEWS_API_KEY=

# Core model and pipeline settings
#
# LLM for triage, scripts, transcript analysis (OpenAI-compatible paths use llm_provider):
#   ollama     — local Ollama (default if reachable)
#   gemini     — Google Gemini (needs GEMINI_API_KEY)
#   openrouter — OpenRouter chat API (needs OPENROUTER_API_KEY)
#   rotating   — alternate OpenRouter + Ollama each request (spread load; needs both)
#
LLM_PROVIDER=ollama
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2
# Optional: if Ollama is down, try Gemini or OpenRouter (set the matching key)
LLM_FALLBACK_TO_GEMINI=0
LLM_FALLBACK_TO_OPENROUTER=0
#
# OpenRouter (https://openrouter.ai/docs/guides/routing/provider-selection)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemma-2-9b-it:free
# OPENROUTER_PROVIDER_SORT=price
# OPENROUTER_PROVIDER_JSON={"sort":"price"}
# OPENROUTER_HTTP_REFERER=
# OPENROUTER_TITLE=OpenSourceNews
# LLM_ROTATION_FAILOVER=1
#
GEMINI_API_KEY=
YT_API_KEY=
YOUTUBE_API_KEY=
ASSEMBLYAI_API_KEY=

# Optional email delivery
MAILAROO_API_KEY=
MAILAROO_TO_EMAIL=
MAILAROO_FROM_EMAIL=
MAILAROO_FROM_NAME=
MAILAROO_TO_NAME=
MAILAROO_API_URL=

# Optional frontend: when the API is on another host (split Railway services).
# Example: https://opensourcenews-api-production.up.railway.app
VITE_API_BASE_URL=
# Only if OPEN_SOURCE_NEWS_API_KEY is set on the API — exposed in the JS bundle; prefer reverse proxy.
VITE_API_BEARER_TOKEN=

# Knowledge base / Qdrant sync
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=scheduler_knowledge_base
QDRANT_DISTANCE=Cosine
QDRANT_BATCH_SIZE=50
QDRANT_RECREATE_COLLECTION=false
QDRANT_EMBEDDING_MODEL=models/text-embedding-004
QDRANT_EMBED_MAX_CHARS=12000
