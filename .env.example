# API Authentication (leave blank to disable auth in dev)
OPEN_SOURCE_NEWS_API_KEY=

# Core model and pipeline settings
GEMINI_API_KEY=
YT_API_KEY=
YOUTUBE_API_KEY=
ASSEMBLYAI_API_KEY=

# Optional email delivery
MAILAROO_API_KEY=
MAILAROO_TO_EMAIL=
MAILAROO_FROM_EMAIL=
MAILAROO_FROM_NAME=
MAILAROO_TO_NAME=
MAILAROO_API_URL=

# Optional frontend: when the API is on another host (split Railway services).
# Example: https://opensourcenews-api-production.up.railway.app
VITE_API_BASE_URL=
# Only if OPEN_SOURCE_NEWS_API_KEY is set on the API — exposed in the JS bundle; prefer reverse proxy.
VITE_API_BEARER_TOKEN=

# Knowledge base / Qdrant sync
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=scheduler_knowledge_base
QDRANT_DISTANCE=Cosine
QDRANT_BATCH_SIZE=50
QDRANT_RECREATE_COLLECTION=false
QDRANT_EMBEDDING_MODEL=models/text-embedding-004
QDRANT_EMBED_MAX_CHARS=12000
