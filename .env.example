# API Authentication
#
# OPEN_SOURCE_NEWS_ADMIN_KEY protects POST/PUT/PATCH/DELETE routes, including feed edits,
# research planning, script generation, and transcript analysis. Set this in production.
# OPEN_SOURCE_NEWS_API_KEY optionally protects read-only report/config endpoints too.
OPEN_SOURCE_NEWS_API_KEY=
OPEN_SOURCE_NEWS_ADMIN_KEY=
OPEN_SOURCE_NEWS_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Core model and pipeline settings
#
# LLM for triage, scripts, transcript analysis (OpenAI-compatible paths use llm_provider):
#   ollama     — local Ollama (default if reachable)
#   gemini     — optional Google Gemini (needs GEMINI_API_KEY; keep server-side only)
#   openrouter — OpenRouter chat API (needs OPENROUTER_API_KEY)
#   rotating   — alternate OpenRouter + Ollama each request (spread load; needs both)
#
LLM_PROVIDER=ollama
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2
# Optional: if Ollama is down, try Gemini or OpenRouter (set the matching key).
# Leave LLM_FALLBACK_TO_GEMINI=0 if you do not want any Gemini usage.
LLM_FALLBACK_TO_GEMINI=0
LLM_FALLBACK_TO_OPENROUTER=0
#
# OpenRouter (https://openrouter.ai/docs/guides/routing/provider-selection)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemma-2-9b-it:free
# OPENROUTER_PROVIDER_SORT=price
# OPENROUTER_PROVIDER_JSON={"sort":"price"}
# Optional guardrails if you use free/limited OpenRouter models in scheduled jobs.
# 0 means no local cap; provider-side limits still apply.
# OPENROUTER_MAX_REQUESTS_PER_RUN=0
# OPENROUTER_MIN_INTERVAL_SECONDS=0
# OPENROUTER_HTTP_REFERER=
# OPENROUTER_TITLE=OpenSourceNews
# LLM_ROTATION_FAILOVER=1
#
# Optional only. Do not put this in any VITE_* variable or public frontend config.
GEMINI_API_KEY=
YT_API_KEY=
YOUTUBE_API_KEY=
ASSEMBLYAI_API_KEY=

# Optional email delivery
MAILAROO_API_KEY=
MAILAROO_TO_EMAIL=
MAILAROO_FROM_EMAIL=
MAILAROO_FROM_NAME=
MAILAROO_TO_NAME=
MAILAROO_API_URL=

# Optional: POST daily JSON digest to another system (agents, OpenSwarm, Agency, etc.)
# after daily_run.py. Payload includes both raw `report` and `normalized` items.
# Local OpenSwarm example: http://localhost:7077/api/opensourcenews/ingest
# Production example: https://your-openswarm-service.com/api/opensourcenews/ingest
# AGENCY_INGEST_URL=
# AGENCY_INGEST_BEARER_TOKEN=
# EXTERNAL_INGEST_URL=
# EXTERNAL_INGEST_BEARER_TOKEN=
# EXTERNAL_INGEST_ENABLED=1
# EXTERNAL_INGEST_INCLUDE_MARKDOWN=1
# EXTERNAL_INGEST_TIMEOUT=90
# EXTERNAL_INGEST_RETRIES=3
# EXTERNAL_INGEST_MAX_MARKDOWN_CHARS=200000
# EXTERNAL_INGEST_HEADERS={"X-Integration":"open_source_news"}

# Optional frontend: when the API is on another host (split Railway services).
# Example: https://opensourcenews-api-production.up.railway.app
VITE_API_BASE_URL=
# Private/dev escape hatch only. Vite embeds this in the public JS bundle.
# Prefer public read endpoints, same-origin proxy auth, or admin-only backend calls.
# This token is ignored unless VITE_ALLOW_BROWSER_BEARER_TOKEN=1 is also set.
VITE_API_BEARER_TOKEN=
VITE_ALLOW_BROWSER_BEARER_TOKEN=0

# Knowledge base / Qdrant sync
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=scheduler_knowledge_base
QDRANT_DISTANCE=Cosine
QDRANT_BATCH_SIZE=50
QDRANT_RECREATE_COLLECTION=false
QDRANT_EMBEDDING_MODEL=models/text-embedding-004
QDRANT_EMBED_MAX_CHARS=12000
